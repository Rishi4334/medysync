# Core backend
PORT=8080
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=replace-this-secret
API_BASE_URL=http://localhost:8080

# MQTT (required for ESP32 + IoT events)
# Example public broker format: mqtts://your-cluster.s1.eu.hivemq.cloud:8883
MQTT_BROKER_URL=
MQTT_CLIENT_ID=medcare-backend
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=medcare

# Firebase Admin (required for Firestore + FCM)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=
# Optional: raw JSON string for service account (alternative to above fields)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Device command behavior
DEVICE_COMMAND_TTL_SECONDS=30
